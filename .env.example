# Environment Variables

# PostgreSQL
DATABASE_URL=postgresql://archiveagents:archiveagents@localhost:5432/archiveagents

# Arc Testnet RPC
ARC_RPC_HTTP=https://rpc.testnet.arc.network
ARC_RPC_WSS=wss://rpc.testnet.arc.network

# IPFS Gateways (comma-separated, tried in order)
IPFS_GATEWAYS=https://ipfs.io/ipfs/,https://gateway.pinata.cloud/ipfs/,https://cloudflare-ipfs.com/ipfs/,https://dweb.link/ipfs/

# Indexer Config
SYNC_CHUNK_SIZE=10000
SYNC_RETRY_MAX=5
SYNC_RETRY_DELAY_MS=1000
METADATA_FETCH_INTERVAL_MS=5000
SCORE_RECOMPUTE_INTERVAL_MS=60000

# Health Server
HEALTH_PORT=3001

# Logging
LOG_LEVEL=info
