# Environment Variables

# ─── Databases ────────────────────────────────────────────────────────────────
# Two separate Postgres databases:
#   - archivehub:     marketplace data (open_jobs, applications, deliverables)
#   - archiveagents:  on-chain indexed data (agents, reputation, validations, sync_state)
#
# Each process uses different env names so a single .env file can serve both:
#   API:        DATABASE_URL → archivehub      (via query())
#               AGENTS_DATABASE_URL → archiveagents  (via queryAgents())
#   Indexer:    AGENTS_DATABASE_URL → archiveagents  (preferred — falls back to DATABASE_URL)
#               MARKETPLACE_DATABASE_URL → archivehub
#   Evaluator:  DATABASE_URL → archivehub
#
# Set BOTH urls explicitly to avoid surprises:
DATABASE_URL=postgresql://archiveagents:archiveagents@localhost:5432/archivehub
AGENTS_DATABASE_URL=postgresql://archiveagents:archiveagents@localhost:5432/archiveagents
MARKETPLACE_DATABASE_URL=postgresql://archiveagents:archiveagents@localhost:5432/archivehub

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Must be at least 32 random chars and not a known weak value.
# Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-openssl-rand-hex-32
JWT_ISSUER=arcs-hive
JWT_AUDIENCE=arcs-hive-api
JWT_EXPIRY=24h
# AUTH_CHAIN_ID must match the chain your app actually uses (Arc Testnet = 5042002).
AUTH_CHAIN_ID=5042002
APP_DOMAIN=arcs-hive.vercel.app

# ─── Docker Compose Postgres ──────────────────────────────────────────────────
POSTGRES_USER=archiveagents
POSTGRES_PASSWORD=changeme
POSTGRES_DB=archiveagents

# ─── API CORS ─────────────────────────────────────────────────────────────────
# Set to your Cloudflare tunnel URL when running API behind tunnel.
# CORS_ORIGIN=https://your-tunnel.trycloudflare.com

# ─── Arc Testnet RPC ──────────────────────────────────────────────────────────
ARC_RPC_HTTP=https://rpc.testnet.arc.network
ARC_RPC_WSS=wss://rpc.testnet.arc.network

# ─── IPFS Gateways (comma-separated, tried in order) ──────────────────────────
IPFS_GATEWAYS=https://ipfs.io/ipfs/,https://gateway.pinata.cloud/ipfs/,https://cloudflare-ipfs.com/ipfs/,https://dweb.link/ipfs/

# ─── Indexer Config ───────────────────────────────────────────────────────────
SYNC_CHUNK_SIZE=10000
SYNC_RETRY_MAX=5
SYNC_RETRY_DELAY_MS=1000
METADATA_FETCH_INTERVAL_MS=5000
SCORE_RECOMPUTE_INTERVAL_MS=60000

# ─── Health Server ────────────────────────────────────────────────────────────
HEALTH_PORT=3001

# ─── Rate limit / proxy trust ─────────────────────────────────────────────────
# Set to the header your trusted edge proxy stamps the real client IP into,
# e.g. cf-connecting-ip. Leave unset if you don't run a trusted proxy.
# TRUSTED_PROXY_HEADER=cf-connecting-ip
# TRUSTED_PROXY_COUNT=1
RATE_LIMIT_MAX=100

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
