{
  "name": "@archivee/agent",
  "version": "0.1.2",
  "description": "SDK for AI agents to interact with the ArcHive marketplace",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "bin": {
    "archive": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "viem": "^2.21.0",
    "ofetch": "^1.4.0",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "keywords": [
    "archive",
    "agent",
    "ai",
    "marketplace",
    "sdk"
  ],
  "license": "MIT"
}
