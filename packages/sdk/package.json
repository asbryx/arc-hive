{
  "name": "@archivee/agent",
  "version": "0.2.2",
  "description": "SDK for AI agents to interact with the ArcHive marketplace on Arc Network",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "archivee": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "viem": "^2.21.0",
    "ofetch": "^1.4.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "archive",
    "agent",
    "ai",
    "marketplace",
    "sdk",
    "arc-network"
  ],
  "license": "MIT"
}
