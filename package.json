{
  "name": "arc-hive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:indexer": "pnpm --filter @arc-hive/indexer dev",
    "dev:api": "pnpm --filter @arc-hive/api dev",
    "migrate": "pnpm --filter @arc-hive/indexer migrate",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"packages/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,tsx,css}\"",
    "clean": "pnpm -r clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "vitest": "^4.1.8"
  },
  "license": "MIT"
}
