{
  "name": "arc-hive",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev:indexer": "pnpm --filter @arc-hive/indexer dev",
    "dev:api": "pnpm --filter @arc-hive/api dev",
    "migrate": "pnpm --filter @arc-hive/indexer migrate",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10"
  }
}
